      <aliases enabled='yes' />
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_2525303920644096]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_flag])' />
      </column>
      <column caption='Total Revenue' datatype='real' default-format='C1033%' name='[Calculation_2525303921233921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_spent])' />
      </column>
      <column caption='Estimated CLV' datatype='real' name='[Calculation_2525303921967107]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[total_spent] * [loyalty_score]' />
      </column>
      <column caption='Engagement Category' datatype='string' name='[Calculation_2525303922278404]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [engagement_score] &gt;= 80 THEN &quot;High&quot;&#13;&#10;ELSEIF [engagement_score] &gt;= 50 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
      </column>
      <column caption='Loyalty Tier' datatype='string' name='[Calculation_2525303922372613]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [loyalty_score] &gt;= 80 THEN &quot;Gold&quot;&#13;&#10;ELSEIF [loyalty_score] &gt;= 50 THEN &quot;Silver&quot;&#13;&#10;ELSE &quot;Bronze&quot;&#13;&#10;END' />
      </column>
      <column caption='High Risk Customer' datatype='integer' name='[Calculation_2525303922565126]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [churn_risk] = &quot;High&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
